pkgbase = niri-git-local
	pkgdesc = Scrollable-tiling Wayland compositor
	pkgver = 25.11
	pkgrel = 2
	url = https://github.com/niri-wm/niri
	arch = x86_64
	arch = aarch64
	license = GPL-3.0-or-later
	makedepends = clang
	makedepends = rust
	makedepends = git
	depends = cairo
	depends = glib2
	depends = libdisplay-info
	depends = libinput
	depends = libpipewire
	depends = libxkbcommon
	depends = mesa
	depends = pango
	depends = pixman
	depends = seatd
	optdepends = fuzzel: application launcher similar to rofi drun mode
	optdepends = waybar: highly customizable Wayland bar
	optdepends = alacritty: a cross-platform OpenGL terminal emulator
	optdepends = mako: notification daemon for Wayland
	optdepends = swaybg: wallpaper tool for Wayland compositors
	optdepends = swaylock: screen locker for Wayland
	optdepends = xdg-desktop-portal-gtk: implements most of the basic functionality
	optdepends = xdg-desktop-portal-gnome: screencasting support
	optdepends = gnome-keyring: implements the secret portal, for certain apps to work
	optdepends = polkit-gnome: when apps need to ask for root permissions
	provides = niri=25.11
	conflicts = niri-bin
	conflicts = niri
	conflicts = niri-git
	options = !debug
	options = !lto
	options = !strip
	source = niri::git+https://github.com/niri-wm/niri.git#tag=v25.11
	source = tag_support-shm-sharing_2.patch::https://github.com/wrvsrx/niri/compare/tag_support-shm-sharing_2~19..tag_support-shm-sharing_2.patch
	b2sums = SKIP
	b2sums = SKIP

pkgname = niri-git-local
